<idea-plugin package="org.cp.lang.clion">
    <id>org.cp.lang.cp</id>
    <name>cp Language Support</name>
    <vendor>kkkzbh</vendor>
    <description><![CDATA[
        CLion support for the cp experimental language: file type registration,
        rich syntax and semantic highlighting, comment handling, brace matching,
        and native parser/semantic diagnostics.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.clion</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="cp" language="cp" extensions="cp" implementationClass="org.cp.lang.clion.CpFileType" fieldName="INSTANCE" />
        <fileTypeOverrider implementation="org.cp.lang.clion.CpFileTypeOverrider" />
        <lang.parserDefinition language="cp" implementationClass="org.cp.lang.clion.CpParserDefinition" />
        <lang.syntaxHighlighterFactory language="cp" implementationClass="org.cp.lang.clion.CpSyntaxHighlighterFactory" />
        <colorSettingsPage implementation="org.cp.lang.clion.CpColorSettingsPage" />
        <annotator language="cp" implementationClass="org.cp.lang.clion.CpAnnotator" />
        <lang.psiStructureViewFactory language="cp" implementationClass="org.cp.lang.clion.CpStructureViewFactory" />
        <lang.commenter language="cp" implementationClass="org.cp.lang.clion.CpCommenter" />
        <lang.braceMatcher language="cp" implementationClass="org.cp.lang.clion.CpBraceMatcher" />
        <lang.quoteHandler language="cp" implementationClass="org.cp.lang.clion.CpQuoteHandler" />
        <langCodeStyleSettingsProvider implementation="org.cp.lang.clion.CpCodeStyleSettingsProvider" />
        <lang.formatter language="cp" implementationClass="org.cp.lang.clion.CpFormattingModelBuilder" />
        <lang.findUsagesProvider language="cp" implementationClass="org.cp.lang.clion.CpFindUsagesProvider" />
        <findUsagesHandlerFactory implementation="org.cp.lang.clion.CpFindUsagesHandlerFactory" />
        <referencesSearch implementation="org.cp.lang.clion.CpReferencesSearch" />
        <lang.documentationProvider language="cp" implementationClass="org.cp.lang.clion.CpDocumentationProvider" />
        <lang.directNavigationProvider implementationClass="org.cp.lang.clion.CpDirectNavigationProvider" />
        <gotoDeclarationHandler implementation="org.cp.lang.clion.CpGotoDeclarationHandler" />
        <renamePsiElementProcessor implementation="org.cp.lang.clion.CpRenameProcessor" />
        <backspaceHandlerDelegate implementation="org.cp.lang.clion.CpBackspaceHandler" />
        <enterHandlerDelegate implementation="org.cp.lang.clion.CpEnterHandler" />
        <externalAnnotator language="cp" implementationClass="org.cp.lang.clion.CpExternalAnnotator" />
        <completion.contributor language="cp" implementationClass="org.cp.lang.clion.CpCompletionContributor" />
        <codeInsight.declarativeInlayProvider providerId="cp.type.hints"
                                               language="cp"
                                               implementationClass="org.cp.lang.clion.CpTypeHintsProvider"
                                               isEnabledByDefault="true"
                                               group="TYPES_GROUP"
                                               bundle="messages.CpBundle"
                                               nameKey="cp.inlay.type.hints.name"
                                               descriptionKey="cp.inlay.type.hints.description" />
        <highlightErrorFilter implementation="org.cp.lang.clion.CpMarkdownErrorFilter" />
        <daemon.externalAnnotatorsFilter implementation="org.cp.lang.clion.CpExternalAnnotatorsFilter" />
        <postStartupActivity implementation="org.cp.lang.clion.CpRealtimeDiagnosticsActivity" />
        <configurationType implementation="org.cp.lang.clion.CpRunConfigurationType" />
        <runConfigurationProducer implementation="org.cp.lang.clion.CpRunConfigurationProducer" />
        <runLineMarkerContributor language="cp" implementationClass="org.cp.lang.clion.CpRunLineMarkerContributor" />
    </extensions>
</idea-plugin>

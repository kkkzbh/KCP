l_paren	(	start_of_line
r_paren	)	leading_space
l_brace	{	leading_space
r_brace	}	leading_space
l_bracket	[	leading_space
r_bracket	]	leading_space
comma	,	leading_space
semicolon	;	leading_space
colon	:	leading_space
colon_colon	::	leading_space
dot	.	leading_space
arrow	->	leading_space
plus	+	leading_space
minus	-	leading_space
star	*	leading_space
slash	/	leading_space
percent	%	leading_space
equal	=	leading_space
equal_equal	==	leading_space
bang_equal	!=	leading_space
less	<	leading_space
less_equal	<=	leading_space
greater	>	leading_space
greater_equal	>=	leading_space
amp	&	leading_space
pipe	|	leading_space
caret	^	leading_space
tilde	~	leading_space
less_less	<<	leading_space
greater_greater	>>	leading_space
plus_plus	++	leading_space
